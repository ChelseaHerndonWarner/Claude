{
  "manifest_version": 3,
  "name": "Literacy Arcade — ORF Fluency Calculator",
  "short_name": "ORF Calculator",
  "version": "1.0.0",
  "description": "One-click access to the Literacy Arcade Oral Reading Fluency Calculator: WCPM, accuracy, and Hasbrouck & Tindal norms.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open the ORF Fluency Calculator",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
